rules_version = '2';

// ============================================================================
// RozgarSync — Firestore Security Rules
// ============================================================================
// Architecture:
//   users/{uid}              — Public profile (WorkerProfile | EmployerProfile)
//   users/{uid}/private/data — PII + financials (encrypted CNIC, EOBI, balances)
//   gigs/{gigId}             — Gig postings with embedded applicants & escrow
//   transactions/{txId}      — Immutable financial ledger (Admin SDK only)
//   agent_decision_logs/{id} — Immutable AI audit trail (Admin SDK only)
//   reviews/{reviewId}       — Worker/employer reviews
//   notifications/{notifId}  — Push notification records
//   services/{serviceId}     — Worker service directory listings
//   ai_jobs/{jobId}          — AI processing queue
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // HELPER FUNCTIONS
    // ========================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isModerator() {
      return isAuthenticated()
        && (request.auth.token.admin == true || request.auth.token.moderator == true);
    }

    // Returns the set of fields that changed between the existing and incoming doc.
    function changedFields() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Checks that the incoming document has ALL of the specified keys.
    function hasAllFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Validates a Pakistani phone number: +92XXXXXXXXXX (13 chars total).
    function isValidPKPhone(phone) {
      return phone is string && phone.matches('^\\+92[0-9]{10}$');
    }

    // Validates a GeoLocation sub-document shape.
    function isValidGeoLocation(loc) {
      return loc is map
        && loc.keys().hasAll(['geopoint', 'geohash', 'city'])
        && loc.geopoint is map
        && loc.geopoint.latitude is number
        && loc.geopoint.longitude is number
        && loc.geopoint.latitude >= -90 && loc.geopoint.latitude <= 90
        && loc.geopoint.longitude >= -180 && loc.geopoint.longitude <= 180
        && loc.geohash is string
        && loc.geohash.size() >= 4 && loc.geohash.size() <= 12
        && loc.city is string
        && loc.city.size() > 0;
    }

    // Validates a PriceRange sub-document.
    function isValidPriceRange(pr) {
      return pr is map
        && pr.min is number && pr.min >= 0
        && pr.max is number && pr.max >= pr.min
        && pr.currency == 'PKR'
        && pr.unit in ['fixed', 'hourly', 'daily'];
    }

    // ========================================================================
    // 1. USERS COLLECTION — Public Profiles
    // ========================================================================

    match /users/{userId} {

      // --- READ ---
      // All authenticated users can read public profiles (needed for discovery).
      allow read: if isAuthenticated();

      // --- CREATE ---
      // Users can only create their own profile. Mandatory fields enforced.
      allow create: if isOwner(userId)
        && hasAllFields(['uid', 'displayName', 'role', 'locale', 'createdAt', 'updatedAt'])
        && request.resource.data.uid == userId
        && request.resource.data.role in ['worker', 'employer']
        && request.resource.data.locale in ['ur', 'en'];

      // --- UPDATE ---
      // Users can update their own profile, EXCEPT:
      //   • `role` — immutable after creation (admin can change via Admin SDK)
      //   • `uid` — immutable always
      //   • `createdAt` — immutable always
      //   • `isVerified` (within profile) — only admin can set
      //   • `safetyProfile`, `safetyScoring` — only Cloud Functions can update
      allow update: if isOwner(userId)
        && !changedFields().hasAny(['uid', 'role', 'createdAt']);

      // Admin can update any user (e.g. toggling verification, role changes).
      allow update: if isAdmin();

      // --- DELETE ---
      // Only admins can delete user profiles.
      allow delete: if isAdmin();

      // ====================================================================
      // 1a. PRIVATE SUB-COLLECTION — PII & Financial Data
      // ====================================================================
      //
      // Firestore path: users/{userId}/private/data
      //
      // Contains:
      //   • encryptedCnic (AES-256-GCM ciphertext, iv, authTag, keyVersion)
      //   • financialProfile (totalEarnings, withdrawableBalance, eobiTracker, paymentMethods)
      //
      // CRITICAL SECURITY INVARIANTS:
      //   • Only the owner or admin can READ.
      //   • Owner can CREATE (initial CNIC submission, adding payment methods).
      //   • Only Cloud Functions (Admin SDK) can UPDATE financial fields.
      //     This prevents workers from inflating their own balances.
      //   • DELETE is admin-only (account deprovisioning).

      match /private/{docId} {
        // Read: owner or admin only
        allow read: if isOwner(userId) || isAdmin();

        // Create: owner can submit initial private data
        allow create: if isOwner(userId)
          && hasAllFields(['uid', 'encryptedCnic'])
          && request.resource.data.uid == userId;

        // Update: ONLY via Admin SDK for financial integrity.
        // We explicitly block all client-side updates to prevent:
        //   • Balance manipulation
        //   • EOBI contribution tampering
        //   • Forging withdrawal records
        //
        // The one exception: users may update their paymentMethods array
        // if that's the ONLY field changing and the financial totals
        // remain untouched. Even this is risky in production — prefer
        // doing it through a Cloud Function as well.
        allow update: if isAdmin();

        // Delete: admin only (account cleanup)
        allow delete: if isAdmin();
      }
    }

    // ========================================================================
    // 2. GIGS COLLECTION
    // ========================================================================
    //
    // Gig lifecycle:
    //   open → assigned → in_progress → completed
    //                                  → cancelled
    //                                  → disputed
    //
    // Escrow lifecycle:
    //   unfunded → funded → released / refunded / disputed

    match /gigs/{gigId} {

      // --- READ ---
      // All authenticated users can browse gigs.
      allow read: if isAuthenticated();

      // --- CREATE ---
      // Only employers can create gigs. We validate:
      //   • Required fields
      //   • Employer owns the gig
      //   • Location is valid
      //   • Budget is valid
      //   • Initial status is 'open'
      //   • Escrow starts unfunded
      //   • Applicant list starts empty
      allow create: if isAuthenticated()
        && hasAllFields([
             'title', 'description', 'category', 'employerId',
             'location', 'city', 'budget', 'status', 'escrow',
             'applicants', 'applicantCount', 'createdAt', 'updatedAt'
           ])
        && request.resource.data.employerId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.escrow.isFunded == false
        && request.resource.data.escrow.releaseStatus == 'unfunded'
        && request.resource.data.applicants.size() == 0
        && request.resource.data.applicantCount == 0
        && isValidGeoLocation(request.resource.data.location)
        && isValidPriceRange(request.resource.data.budget)
        && request.resource.data.category in [
             'plumbing', 'electrical', 'carpentry', 'painting',
             'cleaning', 'moving', 'tailoring', 'cooking',
             'driving', 'tutoring', 'beauty', 'gardening',
             'ac_repair', 'mobile_repair', 'other'
           ];

      // --- UPDATE ---
      // Case 1: Employer can update their own gig (edit details, assign worker).
      // Escrow fields are admin-only (Cloud Functions manage escrow lifecycle).
      allow update: if isOwner(resource.data.employerId)
        && !changedFields().hasAny(['employerId', 'createdAt', 'escrow']);

      // Case 2: Workers can ONLY append themselves to the applicants array.
      // They cannot modify any other field. This is the "apply to gig" action.
      allow update: if isAuthenticated()
        && changedFields().hasOnly(['applicants', 'applicantCount', 'updatedAt'])
        // Append-only: new applicants array must contain all old applicants.
        && request.resource.data.applicants.hasAll(resource.data.applicants)
        // Exactly one new applicant added.
        && request.resource.data.applicantCount == resource.data.applicantCount + 1
        // The gig must still be open to accept applications.
        && resource.data.status == 'open';

      // Case 3: Admin / Cloud Functions can update anything (escrow, status transitions).
      allow update: if isAdmin();

      // --- DELETE ---
      // Employers can only delete their own open, unfunded gigs.
      allow delete: if isOwner(resource.data.employerId)
        && resource.data.status == 'open'
        && resource.data.escrow.isFunded == false;

      // Admins can delete any gig.
      allow delete: if isAdmin();
    }

    // ========================================================================
    // 3. TRANSACTIONS COLLECTION — Immutable Financial Ledger
    // ========================================================================
    //
    // CRITICAL: All writes MUST go through Cloud Functions (Admin SDK).
    // Client-side creates, updates, and deletes are permanently BLOCKED.
    // This is the strongest security invariant in the system.
    //
    // Transaction integrity is further enforced by:
    //   • idempotencyKey — prevents duplicate transactions
    //   • integrityHash — SHA-256 for tamper detection
    //   Both are computed and written by Cloud Functions only.

    match /transactions/{transactionId} {
      // Users can read transactions where they are the source or destination.
      allow read: if isAuthenticated()
        && (resource.data.sourceId == request.auth.uid
            || resource.data.destinationId == request.auth.uid);

      // Admins / moderators can read all transactions for auditing.
      allow read: if isModerator();

      // ALL client-side mutations are BLOCKED. Admin SDK bypasses these rules.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ========================================================================
    // 4. AGENT DECISION LOGS — Immutable AI Audit Trail
    // ========================================================================
    //
    // CRITICAL IMMUTABILITY CONTRACT:
    //   • Documents can ONLY be created by Cloud Functions (Admin SDK).
    //   • Updates are PERMANENTLY FORBIDDEN — no field can ever be modified.
    //   • Deletes are PERMANENTLY FORBIDDEN — logs are retained indefinitely.
    //
    // Integrity is enforced by SHA trace hashes:
    //   • inputHash:      SHA-256 of serialised input
    //   • outputHash:     SHA-256 of serialised output
    //   • traceChainHash: SHA-256(parentTraceId + inputHash + outputHash)
    //     → creates a tamper-evident hash chain across decision sessions.
    //
    // If an auditor re-computes traceChainHash and it doesn't match,
    // that log or a predecessor has been tampered with.

    match /agent_decision_logs/{logId} {
      // Only admins can read audit logs.
      allow read: if isAdmin();

      // Moderators can read for dispute resolution.
      allow read: if isModerator();

      // ALL client-side mutations are BLOCKED.
      allow create: if false;  // Admin SDK bypasses
      allow update: if false;  // IMMUTABLE — never
      allow delete: if false;  // IMMUTABLE — never
    }

    // ========================================================================
    // 5. REVIEWS COLLECTION
    // ========================================================================

    match /reviews/{reviewId} {
      // Anyone authenticated can read reviews (public reputation system).
      allow read: if isAuthenticated();

      // Users can create reviews for gigs they participated in.
      // The Cloud Function should validate that the reviewer actually
      // participated in the gig. Here we enforce basic structure.
      allow create: if isAuthenticated()
        && hasAllFields([
             'gigId', 'reviewerId', 'reviewerName', 'reviewerRole',
             'revieweeId', 'revieweeName', 'rating', 'comment', 'createdAt'
           ])
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.reviewerRole in ['worker', 'employer'];

      // Reviewers can update their own review (edit comment/rating).
      // Cannot change reviewerId, revieweeId, or gigId.
      allow update: if isOwner(resource.data.reviewerId)
        && !changedFields().hasAny(['reviewerId', 'revieweeId', 'gigId', 'createdAt']);

      // Only admins can delete reviews (content moderation).
      allow delete: if isAdmin();
    }

    // ========================================================================
    // 6. NOTIFICATIONS COLLECTION
    // ========================================================================

    match /notifications/{notificationId} {
      // Users can only read their own notifications.
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // Users can ONLY update `isRead` — nothing else.
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && changedFields().hasOnly(['isRead'])
        && request.resource.data.isRead is bool;

      // Create and delete: backend only (Cloud Functions via Admin SDK).
      allow create: if false;
      allow delete: if false;
    }

    // ========================================================================
    // 7. SERVICES COLLECTION (Worker Directory Listings)
    // ========================================================================

    match /services/{serviceId} {
      // Public read for service discovery.
      allow read: if isAuthenticated();

      // Workers create their own service listings.
      allow create: if isAuthenticated()
        && request.resource.data.workerId == request.auth.uid
        && hasAllFields([
             'title', 'category', 'priceRange', 'workerId',
             'location', 'city', 'isActive', 'createdAt', 'updatedAt'
           ])
        && isValidPriceRange(request.resource.data.priceRange)
        && isValidGeoLocation(request.resource.data.location);

      // Workers can update their own listings.
      allow update: if isOwner(resource.data.workerId)
        && !changedFields().hasAny(['workerId', 'createdAt']);

      // Workers can delete their own listings. Admins can delete any.
      allow delete: if isOwner(resource.data.workerId) || isAdmin();
    }

    // ========================================================================
    // 8. AI JOBS COLLECTION
    // ========================================================================

    match /ai_jobs/{jobId} {
      // Users can read their own AI jobs.
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;

      // Admins can read all AI jobs.
      allow read: if isAdmin();

      // Users can create AI job requests (queued for processing).
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'queued';

      // Status transitions and output are managed by Cloud Functions.
      allow update: if false;  // Admin SDK only
      allow delete: if isAdmin();
    }

    // ========================================================================
    // 9. SERVICE CATEGORIES (Reference Data)
    // ========================================================================

    match /categories/{categoryId} {
      allow read: if true; // Public reference data
      allow write: if isAdmin();
    }

    // ========================================================================
    // 10. PLATFORM ANALYTICS (Admin Only)
    // ========================================================================

    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK only
    }
  }
}
